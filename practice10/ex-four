import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.GridPane;
import javafx.stage.Stage;

public class Bai4 extends Application {

    @Override
    public void start(Stage stage) {
        GridPane grid = new GridPane();
        grid.setPadding(new Insets(10));
        grid.setHgap(10);
        grid.setVgap(10);


        TextField txt1 = new TextField();
        TextField txt2 = new TextField();


        Label resultLabel = new Label("Kết quả: ");


        Button btn = new Button("Tính tổng");


        grid.add(new Label("Số thứ nhất:"), 0, 0);
        grid.add(txt1, 1, 0);

        grid.add(new Label("Số thứ hai:"), 0, 1);
        grid.add(txt2, 1, 1);

        grid.add(btn, 0, 2);
        grid.add(resultLabel, 1, 2);


        btn.setOnAction(e -> {
            try {
                double a = Double.parseDouble(txt1.getText());
                double b = Double.parseDouble(txt2.getText());
                resultLabel.setText("Kết quả: " + (a + b));
            } catch (Exception ex) {
                resultLabel.setText("Lỗi!");
            }
        });

        Scene scene = new Scene(grid, 300, 200);
        stage.setScene(scene);
        stage.setTitle("Máy tính cộng");
        stage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
